# ── Copy this file to .env and fill in your actual values ──
# NEVER commit the real .env file to GitHub

# PostgreSQL connection string from Supabase
# Get it from: Supabase Dashboard → Project → Settings → Database → Connection string
# Use the "Session pooler" URL (port 6543) for free-tier compatibility
SUPABASE_URL=postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# API key for the AI chat feature (DocuMind / OpenAI-compatible)
# Get it from your AI provider dashboard
DOCUMIND_API_KEY=your_documind_api_key_here

# Port — Render sets this automatically, leave as 8080 for local dev
PORT=8080
